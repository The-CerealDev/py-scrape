## 🧩 Key Code Sketches

### `config/settings.py`
```python
from pathlib import Path
from dataclasses import dataclass

BASE_DIR = Path(__file__).resolve().parent.parent
DATA_DIR = BASE_DIR / "data"

@dataclass
class ScrapeConfig:
    company: str = "Blackrock"
    start_date: str = "20250101"
    end_date: str = "20260101"
    headless: bool = True
    max_retries: int = 3
    
    @property
    def links_file(self) -> Path:
        return DATA_DIR / "links" / f"{self.company.lower()}_links.txt"
    
    @property
    def output_csv(self) -> Path:
        return DATA_DIR / "output" / f"{self.company.lower()}.csv"
    
    @property
    def skipped_file(self) -> Path:
        return DATA_DIR / "skipped" / "skipped_links.txt"
```

### `scraper/models.py`
```python
from dataclasses import dataclass

@dataclass
class FilingData:
    company: str
    index: str
    filing: str
    position_date: str
    voting_rights: int
    percent_voting: float
    other_instruments: int
    percent_other: str
    total_voting_rights: str
    shares_no_voting_rights: int
    percent_of_shares: float
    percent_isc: float
    link: str
```

### `scraper/driver.py`
```python
from selenium import webdriver
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager

def create_driver(headless: bool = True) -> webdriver.Chrome:
    """Create and return a configured Chrome WebDriver."""
    options = Options()
    if headless:
        options.add_argument("--headless")
        options.add_argument("--disable-gpu")
    options.add_argument("--window-size=1920,1080")
    
    service = Service(ChromeDriverManager().install())
    return webdriver.Chrome(options=options, service=service)
```

### `main.py`
```python
import argparse
from config.settings import ScrapeConfig
from pipeline.runner import run_pipeline

def main():
    parser = argparse.ArgumentParser(description="LSE Form 8.3 Scraper")
    parser.add_argument("--company", default="Blackrock")
    parser.add_argument("--start", default="20250101")
    parser.add_argument("--end", default="20260101")
    parser.add_argument("--mode", choices=["links", "scrape", "full"], default="full")
    parser.add_argument("--no-headless", action="store_true")
    
    args = parser.parse_args()
    config = ScrapeConfig(
        company=args.company,
        start_date=args.start,
        end_date=args.end,
        headless=not args.no_headless,
    )
    run_pipeline(config, mode=args.mode)

if __name__ == "__main__":
    main()
```

